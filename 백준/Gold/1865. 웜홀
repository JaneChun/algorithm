# 문제
# 때는 2020년, 백준이는 월드나라의 한 국민이다.
# 월드나라에는 N개의 지점이 있고 N개의 지점 사이에는 M개의 도로와 W개의 웜홀이 있다.
# (단 도로는 방향이 없으며 웜홀은 방향이 있다.) 웜홀은 시작 위치에서 도착 위치로 가는 하나의 경로인데, 특이하게도 도착을 하게 되면 시작을 하였을 때보다 시간이 뒤로 가게 된다.
# 웜홀 내에서는 시계가 거꾸로 간다고 생각하여도 좋다.
# 시간 여행을 매우 좋아하는 백준이는 한 가지 궁금증에 빠졌다.
# 한 지점에서 출발을 하여서 시간여행을 하기 시작하여 다시 출발을 하였던 위치로 돌아왔을 때, 출발을 하였을 때보다 시간이 되돌아가 있는 경우가 있는지 없는지 궁금해졌다.
# 여러분은 백준이를 도와 이런 일이 가능한지 불가능한지 구하는 프로그램을 작성하여라.

# 입력
# 첫 번째 줄에는 테스트케이스의 개수 TC(1 ≤ TC ≤ 5)가 주어진다.
# 그리고 두 번째 줄부터 TC개의 테스트케이스가 차례로 주어지는데 각 테스트케이스의 첫 번째 줄에는 지점의 수 N(1 ≤ N ≤ 500), 도로의 개수 M(1 ≤ M ≤ 2500), 웜홀의 개수 W(1 ≤ W ≤ 200)이 주어진다.
# 그리고 두 번째 줄부터 M+1개의 줄에 도로의 정보가 주어지는데 각 도로의 정보는 S, E, T 세 정수로 주어진다.
# S와 E는 연결된 지점의 번호, T는 이 도로를 통해 이동하는데 걸리는 시간을 의미한다.
# 그리고 M+2~M+W+1번째 줄까지 웜홀의 정보가 S, E, T 세 정수로 주어지는데 S는 시작 지점, E는 도착 지점, T는 줄어드는 시간을 의미한다.
# T는 10,000보다 작거나 같은 자연수 또는 0이다.
# 두 지점을 연결하는 도로가 한 개보다 많을 수도 있다.
# 지점의 번호는 1부터 N까지 자연수로 중복 없이 매겨져 있다.

# 출력
# TC개의 줄에 걸쳐서 만약에 시간이 줄어들면서 출발 위치로 돌아오는 것이 가능하면 YES, 불가능하면 NO를 출력한다.

# 벨만 포드 알고리즘: 모든 간선을 N-1번 반복해서 relaxation하면 최단거리가 확정된다.
# 그래프에 N개의 노드가 있을 때, 사이클이 없는 최단 경로는 최대 N-1개의 간선을 사용한다.
# 그래서 N-1번 반복하면 모든 경로가 탐색된다.
# iteration 1: 간선 1개 써서 갈 수 있는 최단거리
# iteration 2: 간선 2개 써서 갈 수 있는 최단거리
# ...
# iteration N-1: 간선 N-1개 써서 갈 수 있는 최단거리 → 확정

# relaxation이란
# dist[E] > dist[S] + T 면,
# dist[E] = dist[S] + T로 갱신하는 것 (S를 거쳐서 E로 가는게 더 빠르면 업데이트)


import sys

input = sys.stdin.readline

TC = int(input())
for _ in range(TC):
    N, M, W = map(
        int, input().split()
    )  # N(정점), M(양방향 간선), W(단방향 간선, 음수 가중치)

    edges = []

    for _ in range(M):
        S, E, T = map(int, input().split())
        edges.append((S, E, T))
        edges.append((E, S, T))

    for _ in range(W):
        S, E, T = map(int, input().split())
        edges.append((S, E, -T))

    # 모든 간선을 순서 상관 없이 순회
    dist = [0] * (N + 1)  # 모든 정점을 동시에 시작점을 봄

    for _ in range(N - 1):  # 모든 간선을 N-1번 반복해서 relaxation
        for S, E, T in edges:
            if (
                dist[E] > dist[S] + T
            ):  # 기존의 E까지 가는 경로보다 S를 거쳐 E로 가는 경로가 더 빠르다면,
                dist[E] = (
                    dist[S] + T
                )  # E까지 가는 최단경로를 S를 거쳐 E로 가는 경로로 업데이트한다.

    # (사이클을 감지하기 위해) 한 번 더 relaxation 했을 때 (N번째 relaxation)
    negative_cycle = False
    for S, E, T in edges:
        if dist[E] > dist[S] + T:  # 또 갱신이 일어난다면 음수 사이클임
            negative_cycle = True
            break

    print("YES" if negative_cycle else "NO")


# 예시
# 노드: 1, 2, 3
# 간선: 1→2(+1), 2→3(+1), 3→1(-10)
# dist = [0, 0, 0, 0]  # 인덱스 0은 무시

# iteration 1 (간선 1개까지 허용):
# 3→1(-10): dist[1] = 0 + (-10) = -10
# dist = [0, -10, 0, 0]

# iteration 2 (간선 2개까지 허용):
# 1→2(+1): dist[2] = -10 + 1 = -9
# dist = [0, -10, -9, 0]
# iteration N-1 = 2번째 완료 후
# dist = [0, -10, -9, 0]

# N=3번째 (음수 사이클 체크):
# 2→3(+1): dist[3] = -9 + 1 = -8  → 갱신 발생!
# N-1번에서 확정된 값보다 더 줄어듦 → 음수 사이클 존재 → YES
